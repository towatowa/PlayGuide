<?xml version="1.0" encoding="utf-8"?>
<Page
	x:Class="PlayGuide.SettingsPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="using:PlayGuide"
	mc:Ignorable="d"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="40,30,40,40" Spacing="24">

            <!-- 标题 -->
            <TextBlock local:Loc.Text="Settings"
					   FontSize="28"
					   FontWeight="SemiBold" />

            <!-- ================= 常规 ================= -->
            <TextBlock local:Loc.Text="Normal"
					   FontSize="16"
					   Opacity="0.7"
					   Margin="0,10,0,0" />

            <!-- 语言 -->
            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon Glyph="&#xF2B7;" Grid.Column="0" FontSize="18" Margin="8" />

                    <!-- Global -->
                    <StackPanel Grid.Column="1" Margin="0,8,0,8">
                        <TextBlock local:Loc.Text="Language" FontSize="16" />
                    </StackPanel>

                    <ComboBox Grid.Column="2"
                              x:Name="LanguageComboBox"
							  Width="180"
							  HorizontalAlignment="Right"
                              ItemsSource="{x:Bind ViewModel.LanguageList}"
                              SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:OptionItem">
                                <TextBlock Text="{x:Bind Text}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 主题 -->
            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon Glyph="&#xE793;" Grid.Column="0" FontSize="18" Margin="8" />

                    <TextBlock Grid.Column="1" local:Loc.Text="Theme" FontSize="16" Margin="0,8,0,8" />

                    <ComboBox x:Name="ThemeBox"
							  Grid.Column="2"
							  Width="180"
                              ItemsSource="{x:Bind ViewModel.ThemeList}"
                              SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="local:OptionItem">
                                <TextBlock Text="{x:Bind Text}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 托盘 -->
            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon Glyph="&#xE9F5;" Grid.Column="0" FontSize="18" Margin="8" />
                    <StackPanel Grid.Column="1">
                        <TextBlock local:Loc.Text="SystemTrayRun" />
                        <TextBlock local:Loc.Text="SystemTrayRun_Description" Opacity="0.6" FontSize="12" />
                    </StackPanel>

                    <ToggleSwitch x:Name="TraySwitch"
								  Grid.Column="2"
                                  IsOn="{x:Bind ViewModel.SystemTrayExecute, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <!-- ================= 启动 ================= -->
            <TextBlock local:Loc.Text="StartUp"
					   FontSize="16"
					   Opacity="0.7"
					   Margin="0,10,0,0" />

            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon Glyph="&#xE768;" Grid.Column="0" FontSize="18" Margin="8" />
                    <StackPanel Grid.Column="1">
                        <TextBlock local:Loc.Text="RunAtStartUp" />
                        <TextBlock local:Loc.Text="RunAtStartUp_Description" Opacity="0.6" FontSize="12" />
                    </StackPanel>

                    <ToggleSwitch x:Name="AutoStartSwitch"
								  Grid.Column="2" 
                                  IsOn="{x:Bind ViewModel.AutoStart, Mode=TwoWay}"/>
                </Grid>
            </Border>

            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="6">

                    <!-- 原设置项 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon Glyph="&#xE72E;"
                      Grid.Column="0"
                      FontSize="18"
                      Margin="8" />

                        <StackPanel Grid.Column="1">

                            <TextBlock local:Loc.Text="RunAsAdmin" />

                            <TextBlock local:Loc.Text="RunAsAdmin_Description"
                           Opacity="0.6"
                           FontSize="12" />

                        </StackPanel>

                        <ToggleSwitch x:Name="AdminSwitch"
                          Grid.Column="2"
                          IsOn="{x:Bind ViewModel.RunningAsAdmin, Mode=TwoWay}" />
                    </Grid>

                    <TextBlock local:Loc.Text="RunAsAdminNeedRestart"
                               FontSize="12" 
                               Margin="40,0,0,0"
                               Visibility="{x:Bind ViewModel.HasRestartReason('RunAsAdmin'), Mode=OneWay}">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="Red"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ================= 性能 ================= -->
            <TextBlock Text="性能"
					   FontSize="16"
					   Opacity="0.7"
					   Margin="0,10,0,0" />

            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <FontIcon Glyph="&#xE950;" FontSize="18" Margin="8" />
                        <StackPanel>
                            <TextBlock local:Loc.Text="IntelCpuUseECore" />
                            <TextBlock local:Loc.Text="IntelCpuUseECore_Description" Opacity="0.6" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    <ToggleSwitch x:Name="ECoreSwitch"
								  Grid.Column="1"
                                  HorizontalAlignment="Right" 
                                  IsEnabled="{x:Bind ViewModel.IsIntelCpu(), Mode=OneTime}"
                                  IsOn="{x:Bind ViewModel.IntelCpuUseECore, Mode=TwoWay}"/>
                </Grid>
                    <!--
                    <TextBlock local:Loc.Text="RunAsAdminNeedRestart"
                               FontSize="12" 
                               Margin="40,0,0,0"
                               Visibility="{x:Bind ViewModel.HasRestartReason('IntelCpuUseECore'), Mode=OneWay}">
                               <TextBlock.Foreground>
                                   <SolidColorBrush Color="Red"/>
                               </TextBlock.Foreground>
                    </TextBlock>-->
                </StackPanel>
            </Border>

            <!-- ================= 输入 ================= -->
            <TextBlock Text="输入"
					   FontSize="16"
					   Opacity="0.7"
					   Margin="0,10,0,0" />

            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon Glyph="&#xE765;" Grid.Column="0" FontSize="18" Margin="8" />

                    <TextBlock Grid.Column="1" Text="按键捕获方式" Margin="0,8,0,8" />

                    <ComboBox x:Name="KeyCaptureBox"
							  Grid.Column="2"
							  Width="200"
                              HorizontalAlignment="Right">
                        <ComboBoxItem Content="Hook (全局钩子)" />
                        <ComboBoxItem Content="Raw Input（推荐）" />
                    </ComboBox>
                </Grid>
            </Border>
            <!-- ================= 输入 ================= -->
            <TextBlock Text="快捷键设置"
					   FontSize="16"
					   Opacity="0.7"
					   Margin="0,10,0,0" />
            <Border Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <!-- 全局开关 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE765;" FontSize="18" />
                            <StackPanel>
                                <TextBlock Text="启用快捷键" />
                                <TextBlock Text="全局监听键盘输入"
							               Opacity="0.6"
							               FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1" HorizontalAlignment="Right" Margin="0, 0, -75, 0" />
                    </Grid>

                    <!-- 分割线 -->
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

                    <ListView x:Name="HotkeyList"
                              IsItemClickEnabled="False">

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:HotkeyItemViewModel">

                                <Grid Padding="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="400" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧 -->
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="{x:Bind IconGlyph}"  VerticalAlignment="Center" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" />
                                            <TextBlock Text="{x:Bind Description}"
                                                       Opacity="0.6"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 当前快捷键 -->

                                    <!-- 2. 中间快捷键拆分显示 (重点修改) -->
                                    <ItemsControl Grid.Column="1"
                                                  ItemsSource="{x:Bind SplitKeys}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                        <!-- 设置水平排列并带间距 -->
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="4" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <!-- 每一个按键的样式 -->
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="8,2"
                                                        MinWidth="28">
                                                      <TextBlock Text="{x:Bind}"
                                                                 FontSize="12"
                                                                 FontWeight="SemiBold"
                                                                 HorizontalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 修改按钮 -->
                                    <Button Grid.Column="2"
                                            Content="修改"
                                            Margin="0,10, 0, 10"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center" />
                                    <!--="OnEditHotkeyClick"
                                            Tag="{x:Bind}" /> -->
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>