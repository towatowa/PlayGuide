  <Target Name="RemoveExtraLanguages" AfterTargets="Build">
    <ItemGroup>
      <!-- 1. 定义需要删除的候选文件夹（排除掉你想要的语言） -->
      <!-- 注意：通过增加反斜杠并配合通配符，确保只选中子文件夹 -->
      <UnwantedLanguageFolders Include="$([System.IO.Directory]::GetDirectories('$(OutDir)', '*'))" Exclude="$(OutDir)zh-CN;$(OutDir)en-us;$(OutDir)Assets" />
    </ItemGroup>
    <!-- 2. 执行删除动作 -->
    <RemoveDir Directories="@(UnwantedLanguageFolders)" />
    <!-- 3. (可选) 删除多余的 json 描述文件 -->
    <ItemGroup>
      <UnwantedJsonFiles Include="$(OutDir)workloads*.json" />
    </ItemGroup>
    <Delete Files="@(UnwantedJsonFiles)" />
    <Message Text="清理完成：已移除多余语言包和 JSON 文件。" Importance="high" />
  </Target>
  <Target Name="ZipReleaseOutput" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <!-- 1. 尝试从项目定义中获取版本，如果没有定义则默认为 1.0.0 -->
      <AppVersion Condition="'$(Version)' != ''">$(Version)</AppVersion>
      <AppVersion Condition="'$(AppVersion)' == ''">1.0.0</AppVersion>
      <!-- 设置压缩包的文件名 -->
      <TempZipDir>$(OutDir)TempPublish\</TempZipDir>
      <ZipFileName>$(SolutionDir)Publish\$(ProjectName)_v$(AppVersion)_Release.zip</ZipFileName>
    </PropertyGroup>
    <!-- 1. 创建输出目录 -->
    <MakeDir Directories="$(SolutionDir)Publish" />
    <!-- 2. 如果已存在同名压缩包则先删除 -->
    <Delete Files="$(ZipFileName)" Condition="Exists('$(ZipFileName)')" />
    <!-- 1. 清理并创建临时文件夹 -->
    <RemoveDir Directories="$(TempZipDir)" />
    <MakeDir Directories="$(TempZipDir)" />
    <ItemGroup>
      <!-- 2. 【关键】选择要包含的文件 -->
      <!-- 包含所有文件 -->
      <AllFiles Include="$(OutDir)**\*.*" />
      <!-- 定义要排除的文件/文件夹 -->
      <ExcludeFiles Include="$(OutDir)**\*.pdb" />
      <!-- 排除调试文件 -->
      <ExcludeFiles Include="$(OutDir)workloads*.json" />
      <!-- 排除多余 JSON -->
      <ExcludeFiles Include="$(OutDir)Microsoft.NET.Workload*.json" />
      <!-- 定义要排除的编译产物 -->
      <ExcludeFiles Include="$(OutDir)**\*.lib" />
      <!-- 静态库 (不需要) -->
      <ExcludeFiles Include="$(OutDir)**\*.exp" />
      <!-- 导出文件 (不需要) -->
      <ExcludeFiles Include="$(OutDir)**\*.iobj" />
      <!-- 增量链接文件 (不需要) -->
      <ExcludeFiles Include="$(OutDir)**\*.ipdb" />
      <!-- 增量链接文件 (不需要) -->
      <ExcludeFiles Include="$(OutDir)**\*.winmd" />
      <!-- 排除不需要的语言（只保留 zh-CN 和 en-us） -->
      <!-- 注意：这里的逻辑是先匹配所有子目录，再通过排除项过滤 -->
      <ExcludeLangs Include="$(OutDir)de\**;$(OutDir)fr\**;$(OutDir)it\**;$(OutDir)ja\**;$(OutDir)ko\**;$(OutDir)ru\**" />
      <!-- 最终要拷贝的文件清单 -->
      <FilesToPack Include="@(AllFiles)" Exclude="@(ExcludeFiles);@(ExcludeLangs)" />
    </ItemGroup>
    <!-- 3. 执行拷贝 -->
    <Copy SourceFiles="@(FilesToPack)" DestinationFolder="$(TempZipDir)%(RecursiveDir)" SkipUnchangedFiles="true" />
    <!-- 4. 执行打包 -->
    <MakeDir Directories="$(SolutionDir)Publish" />
    <Delete Files="$(ZipFileName)" />
    <Exec Command="powershell -Command Compress-Archive -Path $(TempZipDir)\* -DestinationPath $(ZipFileName)" />
    <!-- 5. 打包完清理临时目录 -->
    <RemoveDir Directories="$(TempZipDir)" />
    <Message Text="精简版 ZIP 打包完成: $(ZipFileName)" Importance="high" />
  </Target>
